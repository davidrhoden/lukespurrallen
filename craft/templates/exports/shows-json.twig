{% header "Content-Type: application/json; charset=utf-8" %}
 
{% set shows = craft.entries.section('shows').limit(null).order('date desc') %}
 
[
{% for entry in shows %}
  {% set venue = entry.venue.first() %}
  {% set image = entry.showArt.first() %}
  {
    "id": {{ entry.id }},
    "slug": {{ entry.slug|json_encode|raw }},
    "title": {{ entry.title|json_encode|raw }},
    "date": {{ (entry.date ? entry.date|date('c') : null)|json_encode|raw }},
    "startTime": {{ (entry.time ? entry.time|date('H:i') : null)|json_encode|raw }},
    "endTime": {{ (entry.endTime ? entry.endTime|date('H:i') : null)|json_encode|raw }},
    "venue": {
      "name": {{ (venue ? venue.title : null)|json_encode|raw }},
      "website": {{ (venue and venue.website ? venue.website : null)|json_encode|raw }}
    },
    "lineup": {{ (entry.lineUp ?: null)|json_encode|raw }},
    "cover": {{ (entry.cover ?: null)|json_encode|raw }},
    "bodyHtml": {{ (entry.body ?: '')|json_encode|raw }},
    "image": {
      "filename": {{ (image ? image.filename : null)|json_encode|raw }}
    }
  }{% if not loop.last %},{% endif %}
{% endfor %}
]